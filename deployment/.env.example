# Environment variables for ShandorCode deployment
# Copy this to .env and fill in your values

# Domain configuration
DOMAIN=shandor.gozerai.com

# Path to repositories for analysis (on VPS)
# This should be a directory where you'll clone/upload repos to analyze
ANALYSIS_PATH=/var/shandorcode/repos

# Email for Let's Encrypt SSL certificates
LETSENCRYPT_EMAIL=chris@gozerai.com

# Optional: Enable basic authentication (before implementing Zuultimate)
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASS=changeme

# Deployment info
DEPLOY_ENV=production
DEPLOY_VERSION=0.1.0
